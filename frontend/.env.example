# OpenAI API key — required for AI video generation (Sora + GPT-4o-mini)
OPENAI_API_KEY=

# Optional: override the model used for teacher scripts (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: override the Sora video model (default: sora-2)
OPENAI_VIDEO_MODEL=sora-2

# Optional: Sora clip length in seconds — one of 4 | 8 | 12 (default: 12)
OPENAI_VIDEO_SECONDS=12

# Optional: Sora video size — one of 720x1280 | 1280x720 | 1024x1792 | 1792x1024 (default: 1280x720)
OPENAI_VIDEO_SIZE=1280x720

# Next.js server port (default: 3000)
PORT=3000

# FastAPI backend URL (run: cd backend && uvicorn app.main:app --reload)
NEXT_PUBLIC_API_URL=http://localhost:8000
